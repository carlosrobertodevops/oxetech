NODE_ENV=development
STAGE=local
SERVICE_NAME=serverless-elb

# Aws local
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# LocalStack
LOCALSTACK_HOST=http://localhost
EDGE_PORT=4566
AWS_ENDPOINT_URL=http://localhost:4566
LOCALSTACK_HOSTNAME=localhost
LOCALSTACK_AUTH_TOKEN="ls-" ## seu TOKEN

# serverless
LAMBDA_RUNTIME=nodejs20.x
SERVERLESS_DEPLOYMENT_BUCKET=testbucket
SERVERLESS_LICENSE_KEY="" ## sua licensa gratis do serverless
ß
# Deve vir do Terraform:
HTTP_LISTENER_ARN=""

### também podem ser via export assim - apenas tirar os comentários e copiar e colocar no seu terminal
